# ════════════════════════════════════════════════════════════
#  청파중앙교회 홈페이지 환경변수
#  복사 방법: cp .env.local.example .env.local
#  Vercel: 대시보드 → Settings → Environment Variables 에 동일하게 입력
# ════════════════════════════════════════════════════════════

# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# 프로젝트 생성: https://www.sanity.io/get-started
# Project ID: sanity.io/manage → 프로젝트 선택 → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API 토큰 (sanity.io/manage → API → Tokens)
# Read Token : Viewer 권한 — draft 미리보기용
# Write Token: Editor 권한 — 시딩 스크립트 전용 (절대 NEXT_PUBLIC_ 붙이지 말 것)
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# ─── Kakao Maps (오시는 길 지도 연동) ────────────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
# Vercel 도메인을 kakao developers 허용 사이트에 추가 필요
NEXT_PUBLIC_KAKAO_MAP_API_KEY=

# ─── 사이트 URL ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://chungpa21.org

# ─── Sanity Studio 환경변수 (sanity/.env 별도 파일) ──────────────────────────
# sanity/ 폴더 안에 별도로 sanity/.env 파일을 만들어 아래 값을 입력하세요.
#
#   SANITY_STUDIO_PROJECT_ID=your_project_id_here
#   SANITY_STUDIO_DATASET=production
